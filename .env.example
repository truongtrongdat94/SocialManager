# Database
DB_URL=jdbc:postgresql://localhost:5432/social_manager
DB_USERNAME=postgres
DB_PASSWORD=postgres123

# JWT
JWT_SECRET=your-very-long-secret-key-at-least-64-chars-here-change-in-production
JWT_EXPIRATION=86400000

# AES Encryption (exactly 16 or 32 chars)
AES_SECRET=32-byte-secret-key-here-12345678

# External APIs
GEMINI_API_KEY=your-gemini-api-key
LEONARDO_API_KEY=your-leonardo-api-key
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Meta (Facebook/Instagram/Threads)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=http://localhost:8080/api/auth/callback/meta

# TikTok
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_REDIRECT_URI=http://localhost:8080/api/auth/callback/tiktok

# Spring profile (dev | prod)
SPRING_PROFILES_ACTIVE=dev
