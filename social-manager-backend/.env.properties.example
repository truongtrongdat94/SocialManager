# Database
DB_URL=jdbc:postgresql://localhost:5432/social_manager
DB_USERNAME=postgres
DB_PASSWORD=postgres123

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT
JWT_SECRET=your-very-long-secret-key-at-least-64-chars-here-change-in-production
JWT_EXPIRATION=86400000

# AES Encryption (exactly 16 or 32 chars)
AES_SECRET=32-byte-secret-key-here-12345678

# External APIs
GEMINI_API_KEY=your-gemini-api-key
LEONARDO_API_KEY=your-leonardo-api-key
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# FACEBOOK
FACEBOOK_CLIENT_ID=your-facebook-page-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-page-client-secret
FACEBOOK_REDIRECT_URI=http://localhost:8080/api/social-accounts/callback/facebook

# INSTAGRAM
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret
# Must be a valid HTTPS URL
INSTAGRAM_REDIRECT_URI=https://your-domain.com/api/social-accounts/callback/instagram

# THREADS
THREADS_CLIENT_ID=your-threads-client-id
THREADS_CLIENT_SECRET=your-threads-client-secret
# Must be a valid HTTPS URL
THREADS_REDIRECT_URI=https://your-domain.com/api/social-accounts/callback/threads

# TikTok
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
# Must be a valid HTTPS URL
TIKTOK_REDIRECT_URI=https://your-domain.com/api/social-accounts/callback/tiktok

# Spring profile (dev | prod)
SPRING_PROFILES_ACTIVE=dev
